# ───── MongoDB ─────
# Локально (через docker compose):
#   MONGO_URI=mongodb://localhost:27017/lostfound?replicaSet=rs0
# Atlas:
#   MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lostfound?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/lostfound?replicaSet=rs0

# ───── Redis (BullMQ + кеш) ─────
REDIS_HOST=localhost
REDIS_PORT=6379

# ───── API ─────
PORT=3000

# ───── Web ─────
# ВАЖЛИВО: префікс /api/v1 — API глобально префіксований
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
WEB_ORIGIN=http://localhost:3001

# ───── JWT ─────
# Згенерувати:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-random-48-byte-base64url
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=30d

# ───── Email (Resend) ─────
# Без RESEND_API_KEY листи лише логуються в консоль (dev-режим)
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM=Lost & Found <onboarding@resend.dev>

# ───── Адресати службових сповіщень ─────
# Кому слати retention-warnings (через кому)
STAFF_EMAILS=admin@example.com
